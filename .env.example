# 네이버 개발자센터(https://developers.naver.com)에서 애플리케이션 등록 후 발급
# "검색" API 사용 권한이 활성화되어 있어야 합니다.
NAVER_CLIENT_ID=your_client_id_here
NAVER_CLIENT_SECRET=your_client_secret_here

# Anthropic Console(https://console.anthropic.com)에서 발급한 API 키.
# 설정하면 회사 홈페이지 텍스트를 Claude AI가 분석해 본사 대표번호를 직접
# 추출 — 정규식 룰의 사각지대를 메운다. 비워두면 LLM 단계는 건너뜀.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 카카오 개발자센터(https://developers.kakao.com)에서 발급한 REST API 키.
# 카카오맵 키워드 검색으로 회사 정보(상호·주소·전화번호)를 보강한다.
# 네이버 지도와 다른 데이터셋이라 네이버 지도가 못 찾는 회사를 잡는 데 효과적.
# 무료 한도: 300,000 calls/day. 비워두면 카카오맵 단계는 건너뜀.
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
