# Streamlit Community Cloud에 배포할 때 사용할 비밀값 템플릿.
# 이 파일은 예시일 뿐이고, 실제 키는 Streamlit Cloud 대시보드의
# "Settings > Secrets" 화면에 동일한 형식으로 직접 붙여넣으세요.
# (이 파일을 GitHub에 푸시해도 됩니다. 실제 값이 들어있지 않으니까요.)

NAVER_CLIENT_ID = "여기에_네이버_클라이언트_아이디"
NAVER_CLIENT_SECRET = "여기에_네이버_클라이언트_시크릿"

# 공개 URL 보호용 비밀번호. 비워두면 누구나 접속 가능.
APP_PASSWORD = "원하는_비밀번호"
